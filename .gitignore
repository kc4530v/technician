# package-lock.json

# Native / local
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
.kotlin/

# Local env overrides
.env*.local

# Logs / debug
npm-debug.*
yarn-debug.*
yarn-error.*

# OS files
.DS_Store
Thumbs.db
*.pem

# Editor / tooling
.idea/
.vscode/
.claude/
